auto-install-peers=true

# Hoist runtime deps that Next.js loads through dynamic require.resolve
# in next/dist/server/require-hook.js into the project-root node_modules
# so the file tracer (output: "standalone") copies them into the
# standalone tree. Without these hoists on pnpm's strict symlinked
# layout, server.js dies at startup with `Cannot find module ...`:
#   - styled-jsx/package.json
#   - @swc/helpers/_/_interop_require_default
public-hoist-pattern[]=*styled-jsx*
public-hoist-pattern[]=*@swc/helpers*
