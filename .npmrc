auto-install-peers=true

# Hoist styled-jsx into the project-root node_modules so Next.js's file
# tracer (output: "standalone") finds and copies it into the standalone
# tree. Without this hoist on pnpm's strict layout, server.js fails at
# startup with:
#   Error: Cannot find module 'styled-jsx/package.json'
#     at .../next/dist/server/require-hook.js
public-hoist-pattern[]=*styled-jsx*
